rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isValidPublicAppointmentCreate() {
      return request.resource.data.keys().hasAll([
          'userId', 'clientName', 'clientEmail', 'date', 'startTime', 'endTime', 'status', 'createdAt'
        ])
        && request.resource.data.status == 'pending'
        && request.resource.data.userId is string
        && request.resource.data.clientName is string
        && request.resource.data.clientEmail is string
        && request.resource.data.date is string
        && request.resource.data.startTime is string
        && request.resource.data.endTime is string;
    }

    function isValidOccupiedDoc() {
      return request.resource.data.keys().hasOnly(['occupied'])
        && request.resource.data.occupied is list
        && request.resource.data.occupied.size() <= 100;
    }

    function isValidPublicSlotWrite(userId, date) {
      return request.auth == null
        && isValidOccupiedDoc()
        && (
          !exists(/databases/$(database)/documents/bookingSlots/$(userId)/days/$(date))
          && request.resource.data.occupied.size() == 1
          || exists(/databases/$(database)/documents/bookingSlots/$(userId)/days/$(date))
          && request.resource.data.occupied.size()
            == get(/databases/$(database)/documents/bookingSlots/$(userId)/days/$(date)).data.occupied.size() + 1
        );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /businessSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /publicProfiles/{token} {
      allow get: if resource == null && request.auth != null
        || resource != null && resource.data.publicBookingEnabled != false
        || resource != null && isOwner(resource.data.userId);
      allow list: if false;
      allow create, update: if isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /bookingSlots/{userId}/days/{date} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isOwner(userId) || isValidPublicSlotWrite(userId, date);
      allow delete: if isOwner(userId);
    }

    match /appointments/{appointmentId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        || isValidPublicAppointmentCreate();
    }
  }
}
